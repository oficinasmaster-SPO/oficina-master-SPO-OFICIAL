{
  "name": "TemplateBacklog",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "Título do template de tarefa"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição detalhada do template"
    },
    "categoria": {
      "type": "string",
      "description": "Categoria da tarefa (ex: Cursos, Processos, etc)"
    },
    "prioridade": {
      "type": "string",
      "enum": ["baixa", "media", "alta", "critica"],
      "default": "media",
      "description": "Nível de prioridade"
    },
    "impacto": {
      "type": "string",
      "enum": ["financeiro", "entrega", "satisfacao", "multiplo"],
      "description": "Tipo de impacto no cliente"
    },
    "passos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ordem": {
            "type": "integer"
          },
          "descricao": {
            "type": "string"
          },
          "tempo_estimado_horas": {
            "type": "number"
          }
        }
      },
      "default": [],
      "description": "Passos procedurais do template"
    },
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina (para templates customizados)"
    },
    "isDefault": {
      "type": "boolean",
      "default": false,
      "description": "Se é um template padrão do sistema"
    },
    "ativo": {
      "type": "boolean",
      "default": true,
      "description": "Se o template está ativo"
    }
  },
  "required": ["titulo", "descricao"],
  "rls": {
    "create": true,
    "read": true,
    "update": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}