{
  "name": "TemplateBacklog",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "Título do template de tarefa"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição detalhada do template"
    },
    "categoria": {
      "type": "string",
      "description": "Categoria da tarefa"
    },
    "prioridade": {
      "type": "string",
      "enum": ["baixa", "media", "alta", "critica"],
      "default": "media"
    },
    "impacto": {
      "type": "string",
      "enum": ["financeiro", "entrega", "satisfacao", "multiplo"],
      "default": "entrega"
    },
    "passos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ordem": {"type": "integer"},
          "descricao": {"type": "string"},
          "tempo_estimado_horas": {"type": "number"}
        }
      },
      "default": []
    },
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina (customizado)"
    },
    "isDefault": {
      "type": "boolean",
      "default": false
    },
    "ativo": {
      "type": "boolean",
      "default": true
    }
  },
  "required": ["titulo", "descricao"],
  "rls": {
    "create": true,
    "read": true,
    "update": true,
    "delete": {
      "user_condition": {"role": "admin"}
    }
  }
}