{
  "name": "TemplateBacklog",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "Título do template de tarefa"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição detalhada do template"
    },
    "prioridade": {
      "type": "string",
      "enum": ["baixa", "media", "alta", "critica"],
      "default": "media",
      "description": "Prioridade padrão do template"
    },
    "impacto": {
      "type": "string",
      "enum": ["financeiro", "entrega", "satisfacao", "multiplo"],
      "description": "Tipo de impacto no cliente"
    },
    "passos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Lista de passos/checklist do template"
    },
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina (se template específico de cliente)"
    }
  },
  "required": ["titulo", "descricao", "prioridade"],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "workshop_id": "{{user.data.workshop_id}}"
        }
      ]
    },
    "read": true,
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}