{
  "name": "BudgetMeta",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "mes": {
      "type": "string",
      "description": "Mês de referência (YYYY-MM)"
    },
    "faturamento_meta_rs": {
      "type": "number",
      "description": "Meta total de faturamento/base de cálculo em R$ (usado para calcular meta percentual)"
    },
    "item": {
      "type": "string",
      "description": "Nome do item da meta (deve corresponder à descricao do DRELancamento)"
    },
    "categoria": {
      "type": "string",
      "description": "Categoria do item (espelha categoria do DRELancamento)"
    },
    "tipo": {
      "type": "string",
      "enum": ["receita", "despesa"],
      "description": "Se é meta de receita ou despesa"
    },
    "meta_percentual": {
      "type": "number",
      "description": "Meta em percentual do faturamento_meta_rs (0-100). Usado quando tipo_calculo=percentual"
    },
    "meta_fixa_rs": {
      "type": "number",
      "description": "Meta em valor fixo em R$ (alternativa ao percentual)"
    },
    "responsavel_nome": {
      "type": "string",
      "description": "Nome do responsável (cache)"
    },
    "notas": {
      "type": "string",
      "description": "Anotações sobre a meta"
    }
  },
  "required": ["workshop_id", "mes", "item", "categoria"],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {"workshop_id": "{{user.data.workshop_id}}"},
        {"user_condition": {"role": "admin"}}
      ]
    },
    "update": {
      "$or": [
        {"workshop_id": "{{user.data.workshop_id}}"},
        {"user_condition": {"role": "admin"}}
      ]
    },
    "delete": {
      "$or": [
        {"workshop_id": "{{user.data.workshop_id}}"},
        {"user_condition": {"role": "admin"}}
      ]
    }
  }
}