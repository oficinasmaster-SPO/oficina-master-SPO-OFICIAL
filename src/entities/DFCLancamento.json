{
  "name": "DFCLancamento",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "mes": {
      "type": "string",
      "description": "Mês de referência no formato YYYY-MM (ex: 2026-05)"
    },
    "grupo": {
      "type": "string",
      "enum": [
        "operacional",
        "investimento",
        "financiamento",
        "saldo_inicial"
      ],
      "description": "Grupo do fluxo de caixa: operacional, investimento, financiamento ou saldo_inicial (controle)"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "entrada",
        "saida"
      ],
      "description": "Se é uma entrada ou saída de caixa"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição do lançamento"
    },
    "valor": {
      "type": "number",
      "description": "Valor em reais"
    },
    "origem": {
      "type": "string",
      "enum": [
        "manual",
        "dre_automatico"
      ],
      "default": "manual",
      "description": "Se foi inserido manualmente pelo usuário ou mapeado automaticamente do DRE"
    },
    "saldo_inicial": {
      "type": "number",
      "description": "Saldo inicial do mês no caixa/banco. Usado apenas no registro de controle do mês (grupo=saldo_inicial)."
    },
    "detalhes": {
      "type": "object",
      "properties": {
        "bancos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "ID único do registro"
              },
              "nome": {
                "type": "string",
                "description": "Nome do banco (ex: Banco do Brasil, Caixa, Itaú)"
              },
              "tipo_conta": {
                "type": "string",
                "enum": [
                  "corrente",
                  "poupanca",
                  "aplicacao"
                ],
                "description": "Tipo de conta bancária"
              },
              "saldo": {
                "type": "number",
                "description": "Saldo em reais"
              },
              "data": {
                "type": "string",
                "format": "date",
                "description": "Data de atualização do saldo"
              }
            },
            "required": [
              "nome",
              "saldo"
            ]
          },
          "default": [],
          "description": "Lista de bancos com seus saldos"
        },
        "maquinas_cartao": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "ID único do registro"
              },
              "nome": {
                "type": "string",
                "description": "Nome da máquina/gateway (ex: Rede, Stone, Sumup)"
              },
              "gateway_pagamento": {
                "type": "string",
                "description": "Gateway de pagamento (ex: Rede Adquirente, Stone, Sumup, PagSeguro)"
              },
              "saldo": {
                "type": "number",
                "description": "Saldo em recebíveis"
              },
              "data": {
                "type": "string",
                "format": "date",
                "description": "Data de atualização do saldo"
              }
            },
            "required": [
              "nome",
              "saldo"
            ]
          },
          "default": [],
          "description": "Lista de máquinas/gateways de cartão com seus recebíveis"
        },
        "caixa": {
          "type": "number",
          "description": "Valor em dinheiro físico na gaveta"
        }
      },
      "description": "Detalhamento de onde está o dinheiro do saldo inicial (apenas para grupo=saldo_inicial)"
    },
    "fonte_saida": {
      "type": "string",
      "enum": [
        "banco",
        "maquina_cartao",
        "caixa"
      ],
      "description": "De onde saiu o dinheiro para este lançamento de saída (apenas para grupo!=saldo_inicial e tipo=saida)"
    }
  },
  "required": [
    "workshop_id",
    "mes",
    "grupo",
    "tipo",
    "valor"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}