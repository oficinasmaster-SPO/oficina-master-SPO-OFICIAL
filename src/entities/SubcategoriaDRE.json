{
  "name": "SubcategoriaDRE",
  "type": "object",
  "properties": {
    "categoria": {
      "type": "string",
      "description": "Categoria pai (ex: 'operacional', 'pessoas')"
    },
    "label": {
      "type": "string",
      "description": "Nome da subcategoria"
    },
    "workshop_id": {
      "type": "string",
      "description": "null = global, preenchido = customizada por workshop"
    },
    "tipo": {
      "type": "string",
      "enum": ["receita", "despesa"],
      "description": "Se é receita ou despesa"
    },
    "ordem": {
      "type": "integer",
      "default": 0,
      "description": "Ordem de exibição"
    },
    "ativo": {
      "type": "boolean",
      "default": true,
      "description": "Se está ativa para uso"
    },
    "entra_tcmp2": {
      "type": "boolean",
      "default": true,
      "description": "Se entra no cálculo TCMP² (apenas para despesas)"
    }
  },
  "required": ["categoria", "label", "tipo"],
  "rls": {
    "create": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": true,
    "update": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}