{
  "name": "MonthlyAccelerationPlan",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "reference_month": {
      "type": "string",
      "description": "Mês de referência (YYYY-MM)"
    },
    "phase": {
      "type": "integer",
      "enum": [
        1,
        2,
        3,
        4
      ],
      "description": "Fase da oficina no momento da geração"
    },
    "diagnostic_id": {
      "type": "string",
      "description": "ID do diagnóstico que originou o plano"
    },
    "version": {
      "type": "integer",
      "default": 1,
      "description": "Versão do plano (1 = original, 2+ = refinado)"
    },
    "previous_version_id": {
      "type": "string",
      "description": "ID da versão anterior (se refinado)"
    },
    "plan_data": {
      "type": "object",
      "properties": {
        "diagnostic_summary": {
          "type": "string",
          "description": "Resumo do diagnóstico"
        },
        "main_objective_90_days": {
          "type": "string",
          "description": "Objetivo principal dos próximos 90 dias"
        },
        "pillar_directions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pillar_name": {
                "type": "string"
              },
              "direction": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": [
                  "alta",
                  "media",
                  "baixa"
                ]
              }
            }
          },
          "description": "Direcionamentos por pilar"
        },
        "timeline_plan": {
          "type": "object",
          "properties": {
            "short_term": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Ações de curto prazo (0-30 dias)"
            },
            "medium_term": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Ações de médio prazo (30-60 dias)"
            },
            "long_term": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Ações de longo prazo (60-90 dias)"
            }
          }
        },
        "implementation_schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "activity_name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "deadline_days": {
                "type": "integer"
              },
              "status": {
                "type": "string",
                "enum": [
                  "pendente",
                  "em_andamento",
                  "concluida"
                ],
                "default": "pendente"
              },
              "completed_date": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "key_indicators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "indicator_name": {
                "type": "string"
              },
              "current_value": {
                "type": "string"
              },
              "target_value": {
                "type": "string"
              },
              "measurement_frequency": {
                "type": "string"
              }
            }
          }
        },
        "next_steps_week": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Próximos passos para esta semana"
        }
      }
    },
    "user_feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "feedback_date": {
            "type": "string",
            "format": "date-time"
          },
          "feedback_type": {
            "type": "string",
            "enum": [
              "text",
              "audio"
            ]
          },
          "content": {
            "type": "string"
          },
          "audio_url": {
            "type": "string"
          },
          "transcription": {
            "type": "string"
          },
          "user_name": {
            "type": "string"
          }
        }
      }
    },
    "refinement_notes": {
      "type": "string",
      "description": "Notas sobre o refinamento feito pela IA"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativo",
        "refinado",
        "concluido",
        "arquivado"
      ],
      "default": "ativo",
      "description": "Status do plano"
    },
    "completion_percentage": {
      "type": "number",
      "default": 0,
      "description": "Percentual de conclusão do plano"
    },
    "generated_by_ai": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "workshop_id",
    "reference_month",
    "phase"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
