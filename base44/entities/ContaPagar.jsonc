{
  "name": "ContaPagar",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "dre_lancamento_id": {
      "type": "string",
      "description": "ID do lan\u00e7amento DRE de origem"
    },
    "fornecedor_id": {
      "type": "string",
      "description": "ID do fornecedor (opcional)"
    },
    "fornecedor_nome": {
      "type": "string",
      "description": "Nome do fornecedor"
    },
    "contato_telefone": {
      "type": "string"
    },
    "contato_email": {
      "type": "string"
    },
    "valor_original": {
      "type": "number"
    },
    "valor_aberto": {
      "type": "number"
    },
    "valor_pago": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "aberto",
        "parcial",
        "pago",
        "vencido",
        "cancelado"
      ],
      "default": "aberto"
    },
    "processing": {
      "type": "boolean",
      "default": false
    },
    "processing_at": {
      "type": "string",
      "format": "date-time"
    },
    "processing_by": {
      "type": "string"
    },
    "data_vencimento": {
      "type": "string",
      "format": "date"
    },
    "data_emissao": {
      "type": "string",
      "format": "date"
    },
    "numero_documento": {
      "type": "string"
    },
    "tipo_documento": {
      "type": "string"
    },
    "forma_pagamento": {
      "type": "string"
    },
    "parcela_numero": {
      "type": "integer"
    },
    "parcela_total": {
      "type": "integer"
    },
    "centro_custo": {
      "type": "string"
    },
    "categoria": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    },
    "historico_alteracoes": {
      "type": "array",
      "description": "Hist\u00f3rico de altera\u00e7\u00f5es da conta",
      "items": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string",
            "description": "Tipo da a\u00e7\u00e3o: criado, editado, pagamento_registrado, cancelado"
          },
          "usuario_nome": {
            "type": "string"
          },
          "usuario_email": {
            "type": "string"
          },
          "data_hora": {
            "type": "string",
            "format": "date-time"
          },
          "detalhes": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o da altera\u00e7\u00e3o"
          }
        }
      }
    }
  },
  "required": [
    "workshop_id",
    "valor_original",
    "status",
    "data_vencimento"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.workshop_id": "{{user.tenant_workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.workshop_id": "{{user.tenant_workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.workshop_id": "{{user.tenant_workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}