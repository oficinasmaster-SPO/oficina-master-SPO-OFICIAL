{
  "name": "CourseLesson",
  "type": "object",
  "properties": {
    "module_id": {
      "type": "string",
      "description": "ID do módulo pai"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "content_type": {
      "type": "string",
      "enum": [
        "video_youtube",
        "video_upload",
        "text",
        "pdf"
      ],
      "default": "video_youtube"
    },
    "content_url": {
      "type": "string",
      "description": "URL do conteúdo"
    },
    "duration_minutes": {
      "type": "integer",
      "default": 0
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "transcript": {
      "type": "string",
      "description": "Transcrição para IA"
    },
    "progression_rules": {
      "type": "object",
      "properties": {
        "can_advance_if_failed": {
          "type": "boolean",
          "default": true,
          "description": "Permite avançar mesmo reprovado na avaliação"
        },
        "can_retake_assessment": {
          "type": "boolean",
          "default": true,
          "description": "Permite refazer avaliação"
        },
        "can_skip_to_assessment": {
          "type": "boolean",
          "default": true,
          "description": "Permite pular direto para avaliação"
        },
        "next_lesson_unlock": {
          "type": "string",
          "enum": [
            "always",
            "after_completion",
            "after_assessment_attempt"
          ],
          "default": "always",
          "description": "Condição para liberar próxima aula"
        },
        "require_assessment_pass": {
          "type": "boolean",
          "default": false,
          "description": "Exige aprovação na avaliação para considerar completa"
        }
      },
      "default": {
        "can_advance_if_failed": true,
        "can_retake_assessment": true,
        "can_skip_to_assessment": true,
        "next_lesson_unlock": "always",
        "require_assessment_pass": false
      }
    }
  },
  "required": [
    "module_id",
    "title",
    "content_type"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "read": true,
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
