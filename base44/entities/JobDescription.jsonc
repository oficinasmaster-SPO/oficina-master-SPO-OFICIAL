{
  "name": "JobDescription",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "employee_id": {
      "type": "string",
      "description": "ID do colaborador (opcional)"
    },
    "job_title": {
      "type": "string",
      "description": "Nome do cargo"
    },
    "area": {
      "type": "string",
      "enum": [
        "vendas",
        "comercial",
        "marketing",
        "tecnico",
        "administrativo",
        "financeiro",
        "gerencia",
        "operacional",
        "rh",
        "outros"
      ],
      "description": "Área de atuação"
    },
    "previous_experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "desired": {
            "type": "boolean"
          }
        }
      },
      "description": "Experiência prévia"
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "desired": {
            "type": "boolean"
          }
        }
      },
      "description": "Formação escolar"
    },
    "knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "desired": {
            "type": "boolean"
          }
        }
      },
      "description": "Conhecimentos"
    },
    "clients": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "internal": {
            "type": "boolean"
          },
          "external": {
            "type": "boolean"
          }
        }
      },
      "description": "Clientes internos e externos"
    },
    "main_activities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Principais atividades do cargo"
    },
    "main_responsibilities": {
      "type": "string",
      "description": "Principais responsabilidades"
    },
    "co_responsibilities": {
      "type": "string",
      "description": "Co-responsabilidades"
    },
    "personal_attributes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "desired": {
            "type": "boolean"
          }
        }
      },
      "description": "Atributos pessoais"
    },
    "inherent_risks": {
      "type": "string",
      "description": "Riscos inerentes ao cargo"
    },
    "equipment_tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Máquinas, equipamentos, ferramentas"
    },
    "managed_information": {
      "type": "string",
      "description": "Informações administradas pelo cargo"
    },
    "working_conditions": {
      "type": "string",
      "description": "Condições de trabalho"
    },
    "physical_effort": {
      "type": "string",
      "description": "Esforço físico"
    },
    "mental_effort": {
      "type": "string",
      "description": "Esforço mental"
    },
    "visual_effort": {
      "type": "string",
      "description": "Esforço visual"
    },
    "financial_transactions": {
      "type": "string",
      "description": "Volume de transações financeiras"
    },
    "third_party_safety": {
      "type": "string",
      "description": "Responsabilidades pela segurança de terceiros"
    },
    "contact_responsibilities": {
      "type": "string",
      "description": "Responsabilidades por contatos"
    },
    "indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string",
            "description": "Descrição do indicador"
          },
          "target_value": {
            "type": "string",
            "description": "Número/Quantidade alvo"
          },
          "percentage_weight": {
            "type": "string",
            "description": "% quando aplicado"
          },
          "frequency": {
            "type": "string",
            "enum": [
              "diario",
              "semanal",
              "mensal"
            ],
            "description": "Frequência"
          },
          "required": {
            "type": "boolean"
          },
          "desired": {
            "type": "boolean"
          }
        }
      },
      "description": "Indicadores"
    },
    "trainings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Treinamentos necessários"
    },
    "generated_by_ai": {
      "type": "boolean",
      "default": false,
      "description": "Se foi gerado por IA"
    },
    "pdf_url": {
      "type": "string",
      "description": "URL do PDF gerado"
    }
  },
  "required": [
    "job_title"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
