{
  "name": "DRELancamento",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "mes": {
      "type": "string",
      "description": "M\u00eas de refer\u00eancia no formato YYYY-MM (ex: 2026-05)"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "receita",
        "despesa"
      ],
      "description": "Se \u00e9 uma entrada ou sa\u00edda"
    },
    "categoria": {
      "type": "string",
      "description": "Categoria do lan\u00e7amento (operacional, pessoas, marketing, manutencao, terceirizados, administrativo, financeiro, pecas_estoque, pecas_aplicadas, servicos, outras)"
    },
    "subcategoria": {
      "type": "string",
      "description": "Subcategoria espec\u00edfica dentro da categoria"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o livre do lan\u00e7amento"
    },
    "valor": {
      "type": "number",
      "description": "Valor em reais"
    },
    "entra_tcmp2": {
      "type": "boolean",
      "default": true,
      "description": "Se este lan\u00e7amento entra no c\u00e1lculo do TCMP\u00b2. Autom\u00e1tico pela categoria."
    }
  },
  "required": [
    "workshop_id",
    "mes",
    "tipo",
    "categoria",
    "valor"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}