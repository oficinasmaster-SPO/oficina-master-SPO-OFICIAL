{
  "name": "WorkshopMilestone",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "title": {
      "type": "string",
      "description": "T\u00edtulo da conquista (ex: Placa 100k)"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada"
    },
    "category": {
      "type": "string",
      "enum": [
        "faturamento",
        "unidades",
        "equipe",
        "tempo_casa"
      ],
      "default": "faturamento",
      "description": "Categoria da conquista"
    },
    "value_reached": {
      "type": "number",
      "description": "Valor atingido (ex: 100000)"
    },
    "achieved_date": {
      "type": "string",
      "format": "date-time",
      "description": "Data da conquista"
    },
    "icon_name": {
      "type": "string",
      "description": "Nome do \u00edcone para exibi\u00e7\u00e3o"
    },
    "is_physical_award": {
      "type": "boolean",
      "default": false,
      "description": "Se existe pr\u00eamio f\u00edsico (Placa)"
    }
  },
  "required": [
    "workshop_id",
    "title",
    "category"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}