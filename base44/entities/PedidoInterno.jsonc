{
  "name": "PedidoInterno",
  "type": "object",
  "properties": {
    "tipo": {
      "type": "string",
      "enum": [
        "apoio_tecnico",
        "decisao_estrategica",
        "liberacao_material",
        "excecao_escopo",
        "outros"
      ],
      "description": "Tipo de pedido interno"
    },
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do pedido"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada do pedido"
    },
    "solicitante_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio solicitante"
    },
    "solicitante_nome": {
      "type": "string",
      "description": "Nome do solicitante"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio respons\u00e1vel"
    },
    "responsavel_nome": {
      "type": "string",
      "description": "Nome do respons\u00e1vel"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente relacionado"
    },
    "cliente_nome": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "prazo": {
      "type": "string",
      "format": "date",
      "description": "Prazo para resolu\u00e7\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "em_analise",
        "aprovado",
        "recusado",
        "concluido"
      ],
      "default": "pendente",
      "description": "Status atual do pedido"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta",
        "critica"
      ],
      "default": "media",
      "description": "Prioridade do pedido"
    },
    "impacto_cliente": {
      "type": "string",
      "enum": [
        "nenhum",
        "baixo",
        "medio",
        "alto",
        "critico"
      ],
      "default": "medio",
      "description": "Impacto no cliente"
    },
    "resposta": {
      "type": "string",
      "description": "Resposta/resolu\u00e7\u00e3o do pedido"
    },
    "midias_anexas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "imagem",
              "arquivo",
              "link"
            ],
            "description": "Tipo de m\u00eddia"
          },
          "url": {
            "type": "string",
            "description": "URL da m\u00eddia"
          },
          "nome": {
            "type": "string",
            "description": "Nome/t\u00edtulo da m\u00eddia"
          },
          "uploaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "Data de upload"
          }
        }
      },
      "default": [],
      "description": "M\u00eddias, imagens, documentos e links anexados"
    },
    "arquivos_anexos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "description": "Arquivos anexados ao pedido (legado)"
    },
    "data_conclusao": {
      "type": "string",
      "format": "date-time",
      "description": "Data de conclus\u00e3o"
    },
    "data_primeira_resposta": {
      "type": "string",
      "format": "date-time",
      "description": "Data da primeira resposta"
    },
    "vencido": {
      "type": "boolean",
      "default": false,
      "description": "Se o pedido est\u00e1 vencido"
    },
    "historico": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "acao": {
            "type": "string"
          },
          "campo": {
            "type": "string"
          },
          "valor_anterior": {
            "type": "string"
          },
          "valor_novo": {
            "type": "string"
          },
          "usuario_id": {
            "type": "string"
          },
          "usuario_nome": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "default": [],
      "description": "Hist\u00f3rico de altera\u00e7\u00f5es do pedido"
    }
  },
  "required": [
    "tipo",
    "titulo",
    "solicitante_id",
    "responsavel_id",
    "prazo"
  ],
  "rls": {
    "create": true,
    "read": true,
    "update": {
      "$or": [
        {
          "solicitante_id": "{{user.id}}"
        },
        {
          "responsavel_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}