{
  "name": "PerformanceMatrixDiagnostic",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string",
      "description": "ID do colaborador avaliado"
    },
    "evaluator_id": {
      "type": "string",
      "description": "ID do usuário que fez a avaliação"
    },
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa"
    },
    "consulting_firm_id": {
      "type": "string",
      "description": "ID da consultoria"
    },
    "evaluation_type": {
      "type": "string",
      "enum": [
        "manager",
        "self"
      ],
      "default": "manager",
      "description": "Tipo de avaliação: Gestor ou Autoavaliação"
    },
    "technical_scores": {
      "type": "object",
      "properties": {
        "conhece_funcao": {
          "type": "number"
        },
        "atinge_resultados": {
          "type": "number"
        },
        "baixo_retrabalho": {
          "type": "number"
        },
        "trabalha_alto_nivel": {
          "type": "number"
        },
        "toma_decisoes": {
          "type": "number"
        },
        "contribui_ideias": {
          "type": "number"
        },
        "produz_qualidade": {
          "type": "number"
        },
        "prioridade_certa": {
          "type": "number"
        },
        "sistemas_eficientes": {
          "type": "number"
        },
        "transmite_informacoes": {
          "type": "number"
        },
        "cumpre_compromissos": {
          "type": "number"
        },
        "informa_impossibilidades": {
          "type": "number"
        },
        "da_recebe_feedback": {
          "type": "number"
        },
        "excede_expectativas": {
          "type": "number"
        },
        "busca_conhecimento": {
          "type": "number"
        },
        "compreende_tecnologias": {
          "type": "number"
        },
        "desenvolvimento_profissional": {
          "type": "number"
        }
      },
      "description": "Notas dos 17 critérios técnicos (0-10)"
    },
    "emotional_scores": {
      "type": "object",
      "properties": {
        "autoconfianca": {
          "type": "number"
        },
        "autocontrole": {
          "type": "number"
        },
        "superacao": {
          "type": "number"
        },
        "iniciativa": {
          "type": "number"
        },
        "transparencia": {
          "type": "number"
        },
        "flexibilidade": {
          "type": "number"
        },
        "otimismo": {
          "type": "number"
        },
        "empatia": {
          "type": "number"
        },
        "servico": {
          "type": "number"
        },
        "lideranca": {
          "type": "number"
        },
        "influencia": {
          "type": "number"
        },
        "gerenciamento_conflitos": {
          "type": "number"
        },
        "trabalho_equipe": {
          "type": "number"
        }
      },
      "description": "Notas dos 13 critérios emocionais (0-10)"
    },
    "technical_average": {
      "type": "number",
      "description": "Média das competências técnicas"
    },
    "emotional_average": {
      "type": "number",
      "description": "Média das competências emocionais"
    },
    "classification": {
      "type": "string",
      "enum": [
        "demissao",
        "treinamento_tecnico",
        "treinamento_emocional",
        "observacao",
        "reconhecimento",
        "investimento"
      ],
      "description": "Classificação na matriz"
    },
    "recommendation": {
      "type": "string",
      "description": "Recomendação automática baseada na classificação"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Diagnóstico completo"
    }
  },
  "required": [
    "employee_id",
    "evaluator_id",
    "technical_scores",
    "emotional_scores"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "workshop_id": "{{user.data.workshop_id}}"
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "consulting_firm_id": "{{user.data.consulting_firm_id}}"
            },
            {
              "user_condition": {
                "data.user_type": "internal"
              }
            }
          ]
        },
        {
          "$and": [
            {
              "company_id": "{{user.data.company_id}}"
            },
            {
              "user_condition": {
                "data.user_type": "internal"
              }
            }
          ]
        },
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "consulting_firm_id": "{{user.data.consulting_firm_id}}"
            },
            {
              "user_condition": {
                "data.user_type": "internal"
              }
            }
          ]
        },
        {
          "$and": [
            {
              "company_id": "{{user.data.company_id}}"
            },
            {
              "user_condition": {
                "data.user_type": "internal"
              }
            }
          ]
        },
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "consulting_firm_id": "{{user.data.consulting_firm_id}}"
            },
            {
              "user_condition": {
                "data.user_type": "internal"
              }
            }
          ]
        },
        {
          "$and": [
            {
              "company_id": "{{user.data.company_id}}"
            },
            {
              "user_condition": {
                "data.user_type": "internal"
              }
            }
          ]
        },
        {
          "workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
