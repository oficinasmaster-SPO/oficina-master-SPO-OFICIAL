{
  "name": "ContaReceber",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "dre_lancamento_id": {
      "type": "string",
      "description": "ID do lan\u00e7amento DRE de origem"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente (opcional)"
    },
    "cliente_nome": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "contato_telefone": {
      "type": "string",
      "description": "Telefone/WhatsApp para contato sobre esta conta"
    },
    "contato_email": {
      "type": "string",
      "description": "E-mail para contato sobre esta conta"
    },
    "valor_original": {
      "type": "number",
      "description": "Valor original da conta"
    },
    "valor_aberto": {
      "type": "number",
      "description": "Valor ainda n\u00e3o pago"
    },
    "valor_pago": {
      "type": "number",
      "description": "Valor j\u00e1 pago"
    },
    "status": {
      "type": "string",
      "enum": [
        "aberto",
        "parcial",
        "pago",
        "vencido",
        "cancelado",
        "antecipado"
      ],
      "default": "aberto",
      "description": "Status da conta"
    },
    "processing": {
      "type": "boolean",
      "default": false,
      "description": "Lock otimista"
    },
    "processing_at": {
      "type": "string",
      "format": "date-time"
    },
    "processing_by": {
      "type": "string"
    },
    "data_vencimento": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento"
    },
    "data_emissao": {
      "type": "string",
      "format": "date",
      "description": "Data de emiss\u00e3o"
    },
    "data_primeiro_pagamento": {
      "type": "string",
      "format": "date",
      "description": "Data do primeiro pagamento"
    },
    "numero_documento": {
      "type": "string"
    },
    "tipo_documento": {
      "type": "string",
      "enum": [
        "nota_fiscal",
        "recibo",
        "duplicata",
        "carne",
        "boleto"
      ]
    },
    "forma_pagamento": {
      "type": "string",
      "enum": [
        "pix",
        "ted",
        "boleto",
        "cartao_credito",
        "cartao_debito",
        "dinheiro",
        "cheque"
      ]
    },
    "parcela_numero": {
      "type": "integer"
    },
    "parcela_total": {
      "type": "integer"
    },
    "desconto": {
      "type": "number",
      "default": 0
    },
    "juros": {
      "type": "number",
      "default": 0
    },
    "multa": {
      "type": "number",
      "default": 0
    },
    "dias_atraso": {
      "type": "integer",
      "default": 0
    },
    "observacoes": {
      "type": "string"
    },
    "historico_alteracoes": {
      "type": "array",
      "description": "Hist\u00f3rico de altera\u00e7\u00f5es da conta",
      "items": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string",
            "description": "Tipo da a\u00e7\u00e3o: criado, editado, recebimento_registrado, cancelado"
          },
          "usuario_nome": {
            "type": "string"
          },
          "usuario_email": {
            "type": "string"
          },
          "data_hora": {
            "type": "string",
            "format": "date-time"
          },
          "detalhes": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o da altera\u00e7\u00e3o"
          }
        }
      }
    }
  },
  "required": [
    "workshop_id",
    "valor_original",
    "status",
    "data_vencimento"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.workshop_id": "{{user.workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.workshop_id": "{{user.workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.workshop_id": "{{user.workshop_id}}"
        },
        {
          "data.workshop_id": "{{user.data.workshop_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}