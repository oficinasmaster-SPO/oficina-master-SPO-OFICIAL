{
  "name": "LessonAssessment",
  "type": "object",
  "properties": {
    "lesson_id": {
      "type": "string",
      "description": "ID da aula relacionada"
    },
    "type": {
      "type": "string",
      "enum": [
        "quiz",
        "exercise",
        "poll"
      ],
      "description": "Tipo de avaliação"
    },
    "title": {
      "type": "string",
      "description": "Título da avaliação"
    },
    "description": {
      "type": "string",
      "description": "Instruções"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "multiple_choice",
              "text",
              "boolean"
            ]
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Opções para múltipla escolha"
          },
          "correct_answer": {
            "type": "string",
            "description": "Índice ou valor da resposta correta"
          }
        }
      },
      "description": "Lista de perguntas"
    },
    "ai_prompt_template": {
      "type": "string",
      "description": "Instruções para a IA gerar feedback sobre as respostas"
    },
    "passing_score": {
      "type": "number",
      "default": 70,
      "description": "Nota mínima para aprovação (0-100)"
    }
  },
  "required": [
    "lesson_id",
    "type",
    "questions"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "read": true,
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
