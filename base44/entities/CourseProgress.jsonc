{
  "name": "CourseProgress",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID do usuário/colaborador"
    },
    "course_id": {
      "type": "string"
    },
    "lesson_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "completed"
      ],
      "default": "not_started"
    },
    "progress_percentage": {
      "type": "number",
      "default": 0,
      "description": "Porcentagem assistida (0-100)"
    },
    "last_watched_position": {
      "type": "number",
      "default": 0,
      "description": "Posição em segundos onde parou"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "watch_time_seconds": {
      "type": "integer",
      "default": 0,
      "description": "Tempo total assistido"
    }
  },
  "required": [
    "user_id",
    "course_id",
    "lesson_id"
  ],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
