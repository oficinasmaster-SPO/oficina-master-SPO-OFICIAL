{
  "name": "Reward",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio"
    },
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "type": {
      "type": "string",
      "enum": [
        "badge",
        "reconhecimento",
        "destaque",
        "certificado"
      ],
      "description": "Tipo de recompensa"
    },
    "title": {
      "type": "string",
      "description": "T\u00edtulo da recompensa"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o"
    },
    "icon": {
      "type": "string",
      "description": "Nome do \u00edcone"
    },
    "color": {
      "type": "string",
      "description": "Cor da recompensa"
    },
    "awarded_for": {
      "type": "string",
      "description": "Motivo da conquista"
    },
    "awarded_date": {
      "type": "string",
      "format": "date-time"
    },
    "xp_earned": {
      "type": "integer",
      "default": 0
    },
    "is_public": {
      "type": "boolean",
      "default": true,
      "description": "Se aparece no mural p\u00fablico"
    },
    "challenge_id": {
      "type": "string",
      "description": "ID do desafio relacionado"
    }
  },
  "required": [
    "user_id",
    "type",
    "title"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "user_id": "{{user.id}}"
        },
        {
          "is_public": true
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}