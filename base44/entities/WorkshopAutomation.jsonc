{
  "name": "WorkshopAutomation",
  "type": "object",
  "properties": {
    "workshop_id": {
      "type": "string",
      "description": "ID da oficina"
    },
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Se a automação está ativa geral"
    },
    "whatsapp_enabled": {
      "type": "boolean",
      "default": false
    },
    "frequency": {
      "type": "string",
      "enum": [
        "diario",
        "semanal",
        "apenas_eventos"
      ],
      "default": "apenas_eventos"
    },
    "recipients": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "employee_id": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "active": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "description": "Lista de colaboradores configurados para receber"
    },
    "selected_categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Categorias de mensagens ativas (ex: bom_dia, meta_batida)"
    }
  },
  "required": [
    "workshop_id"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "user_type": "internal"
          }
        },
        {
          "user_condition": {
            "data": {
              "user_type": "internal"
            }
          }
        }
      ]
    }
  }
}
