  "memory_config": {
    "enabled": true,
    "scope": "both",
    "instructions": "{\n  \"memory_system\": {\n    \"name\": \"ClientMemoryEngine\",\n    \"description\": \"Sistema de mem\u00f3ria cont\u00ednua do cliente para registrar intera\u00e7\u00f5es, an\u00e1lises, decis\u00f5es e evolu\u00e7\u00e3o estrat\u00e9gica ao longo do tempo\",\n\n    \"storage_scope\": \"cliente\",\n\n    \"storage_location\": {\n      \"primary\": \"InteligenciaCliente\",\n      \"secondary\": [\n        \"Historico\",\n        \"RegistroDiario\",\n        \"CentralFollowUp\",\n        \"RelatoriosInteligencia\"\n      ]\n    },\n\n    \"memory_types\": [\n      {\n        \"type\": \"interacao_consultor\",\n        \"description\": \"Resumo de conversas entre consultor e agente durante atendimentos\",\n        \"fields\": [\n          \"data_hora\",\n          \"consultor\",\n          \"resumo_conversa\",\n          \"contexto_cliente\",\n          \"decisoes_tomadas\",\n          \"proximos_passos\"\n        ]\n      },\n      {\n        \"type\": \"diagnostico_evolutivo\",\n        \"description\": \"An\u00e1lises cont\u00ednuas sobre o estado do cliente\",\n        \"fields\": [\n          \"data_hora\",\n          \"status_cliente\",\n          \"principais_gargalos\",\n          \"riscos_identificados\",\n          \"oportunidades_identificadas\",\n          \"nivel_execucao\",\n          \"nivel_engajamento\"\n        ]\n      },\n      {\n        \"type\": \"insights_estrategicos\",\n        \"description\": \"Ideias discutidas, hip\u00f3teses e caminhos estrat\u00e9gicos levantados\",\n        \"fields\": [\n          \"data_hora\",\n          \"insight\",\n          \"contexto\",\n          \"potencial_impacto\",\n          \"status_insight\"\n        ]\n      },\n      {\n        \"type\": \"decisoes_estrategicas\",\n        \"description\": \"Decis\u00f5es relevantes tomadas ao longo da consultoria\",\n        \"fields\": [\n          \"data_hora\",\n          \"decisao\",\n          \"motivo\",\n          \"impacto_esperado\",\n          \"responsavel\",\n          \"status_execucao\"\n        ]\n      },\n      {\n        \"type\": \"comportamento_cliente\",\n        \"description\": \"Padr\u00f5es de comportamento e perfil do cliente\",\n        \"fields\": [\n          \"data_hora\",\n          \"padrao_identificado\",\n          \"nivel_engajamento\",\n          \"resistencia_ou_facilidade\",\n          \"observacoes\"\n        ]\n      },\n      {\n        \"type\": \"uso_sistema\",\n        \"description\": \"Como o cliente utiliza o sistema e seu n\u00edvel de ado\u00e7\u00e3o\",\n        \"fields\": [\n          \"data_hora\",\n          \"frequencia_uso\",\n          \"modulos_utilizados\",\n          \"modulos_nao_utilizados\",\n          \"nivel_aderencia\",\n          \"alertas\"\n        ]\n      }\n    ],\n\n    \"write_rules\": [\n      \"toda_interacao_relevante_deve_ser_salva\",\n      \"toda_decisao_importante_deve_ser_registrada\",\n      \"todo_insight_estrategico_deve_ser_armazenado\",\n      \"toda_identificacao_de_gargalo_ou_risco_deve_ser_salva\",\n      \"evitar_registros_genericos_ou_sem_valor\",\n      \"priorizar_clareza_e_utilidade_futura\"\n    ],\n\n    \"update_rules\": [\n      \"atualizar_memorias_existentes_quando_houver_evolucao\",\n      \"manter_historico_de_mudancas\",\n      \"nunca_apagar_memorias_relevantes\",\n      \"marcar_status_de_itens_como_evoluido_concluido_ou_pendente\"\n    ],\n\n    \"retrieval_rules\": [\n      \"sempre_consultar_memorias_antes_de_responder\",\n      \"priorizar_memorias_mais_recentes\",\n      \"considerar_evolucao_historica_do_cliente\",\n      \"cruzar_memorias_com_dados_do_sistema\"\n    ],\n\n    \"memory_quality_control\": {\n      \"avoid\": [\n        \"informacoes_redundantes\",\n        \"frases_genericas\",\n        \"conteudo_sem_acao\",\n        \"dados_sem_contexto\"\n      ],\n      \"enforce\": [\n        \"clareza\",\n        \"objetividade\",\n        \"valor_estrategico\",\n        \"facilidade_de_recuperacao\"\n      ]\n    },\n\n    \"goal\": \"Criar uma base de intelig\u00eancia viva do cliente, permitindo que qualquer consultor ou agente entenda rapidamente o hist\u00f3rico, contexto, decis\u00f5es e evolu\u00e7\u00e3o estrat\u00e9gica, garantindo continuidade, profundidade e aumento de performance na consultoria\"\n  }\n}"
  },
  "name": "followup_consultor"
